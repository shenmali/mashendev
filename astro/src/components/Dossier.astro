---
import {
  identity,
  focus,
  experience,
  skills,
  education,
  certs,
  github,
  role,
  tagline,
  ui,
  type Locale,
} from '../content/portfolio';

export interface Props { locale: Locale }
const { locale } = Astro.props;
const t = ui[locale];
---
<section class="v6-dossier-wrap">
  <div class="v3-masthead">
    <span class="wordmark">MASHEN.DEV</span>
    <div class="rule"></div>
    <span class="id">DOSSIER / 001 · REV 2026.Q2 · {identity.location.toUpperCase()}</span>
  </div>
  <h1 class="v3-title">M. ALİ <em>ŞEN</em></h1>
  <p class="v3-sub">{role[locale]} — {tagline[locale]}</p>

  <!-- FOCUS GRID -->
  <div id="focus" class="section-head">
    <span class="lbl">§ {t.sections.focus}</span>
    <div class="rule"></div>
    <span class="meta">{String(focus.length).padStart(2, '0')} ENTRIES</span>
  </div>

  <div class="v3-grid">
    {focus.map((f, i) => (
      <article class="v3-card">
        <span class="idx">{String(i + 1).padStart(2, '0')} / {String(focus.length).padStart(2, '0')}</span>
        <div class="code">[{f.code}]</div>
        <h3>{f.title[locale]}</h3>
        <p>{f.body[locale]}</p>
        <div class="stack">
          {f.stack.map((s) => <span class="tag" style="color:var(--muted);border-color:var(--line)">{s}</span>)}
        </div>
        <div class="v6-proof">{f.proof[locale]}</div>
      </article>
    ))}
  </div>

  <!-- WORK + SKILLS -->
  <div id="work" class="work-skills-grid">
    <div>
      <div class="section-head">
        <span class="lbl">§ {t.sections.work}</span>
        <div class="rule"></div>
      </div>
      {experience.map((e, i) => (
        <div class={`exp-row ${i > 0 ? 'bordered' : ''}`}>
          <div class="mono year">{e.year}</div>
          <div>
            <div class="mono co">
              {e.company}
              {e.tag === 'current' && <span class="tag" style="margin-left:10px">● NOW</span>}
            </div>
            <div class="role-l">{e.role[locale]}</div>
            <div class="note-l">{e.note[locale]}</div>
          </div>
        </div>
      ))}
    </div>

    <div>
      <div class="section-head">
        <span class="lbl">§ {t.sections.skills}</span>
        <div class="rule"></div>
        <span class="meta">0 — 6</span>
      </div>
      {skills.map((s) => (
        <div class="skillbar">
          <span class="label">{s.name}</span>
          <span class="track">
            {Array.from({ length: 6 }).map((_, j) => (
              <span class={`cell${j < s.level ? ' on' : ''}`}></span>
            ))}
          </span>
          <span class="num">{s.level}</span>
        </div>
      ))}
    </div>
  </div>

  <!-- GITHUB REPOS -->
  <div id="repos" class="repos-head">
    <span class="lbl">§ {t.sections.repos}</span>
    <div class="rule"></div>
    <span class="meta">github.com/{identity.github}</span>
    <a href={`https://github.com/${identity.github}`} class="all-link">{t.cta.allRepos}</a>
  </div>
  <div class="v6-repos">
    {github.map((r) => (
      <a href={r.url} class="v6-repo" target="_blank" rel="noopener noreferrer">
        <div class="v6-repo-head">
          <span class="v6-repo-icon">
            <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/>
            </svg>
          </span>
          <span class="v6-repo-name">{r.name}</span>
          <span class="v6-repo-arrow">↗</span>
        </div>
        <p class="v6-repo-desc">{r.desc[locale]}</p>
        <div class="v6-repo-tags">
          {r.tags.map((tag) => <span class="tag">{tag}</span>)}
        </div>
      </a>
    ))}
  </div>

  <!-- EDU + CERTS + CONTACT -->
  <div id="contact" class="edu-certs-contact">
    <div>
      <div class="subhead">{t.sections.edu}</div>
      {education.map((e) => (
        <div class="edu-row">
          <div class="mono edu-year">{e.year}</div>
          <div class="edu-degree">{e.degree}</div>
          <div class="edu-school">{e.school}</div>
        </div>
      ))}
    </div>
    <div>
      <div class="subhead">{t.sections.certs}</div>
      {certs.map((c) => (
        <div class="mono cert-row">→ {c}</div>
      ))}
    </div>
    <div>
      <div class="subhead">{t.sections.contact}</div>
      <div class="contact-list mono">
        <div><span class="k">email</span><a class="v" href={`mailto:${identity.email}`}>{identity.email}</a></div>
        <div><span class="k">git</span><a class="v" href={`https://github.com/${identity.github}`}>github.com/{identity.github}</a></div>
        <div><span class="k">in</span><a class="v" href={`https://linkedin.com/in/${identity.linkedin}`}>linkedin.com/in/{identity.linkedin}</a></div>
        <div><span class="k">medium</span><a class="v" href={`https://medium.com/${identity.medium}`}>medium.com/{identity.medium}</a></div>
        <div><span class="k">cv</span><a class="v" href="/cv.pdf" download>↓ cv.pdf</a></div>
      </div>
    </div>
  </div>
</section>

<style>
  .section-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .section-head .lbl {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .section-head .rule {
    height: 1px;
    background: repeating-linear-gradient(90deg, var(--line) 0 6px, transparent 6px 12px);
  }
  .section-head .meta {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--muted);
  }

  .work-skills-grid {
    margin-top: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
  }

  .exp-row {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 14px;
    padding: 14px 0;
  }
  .exp-row.bordered { border-top: 1px solid var(--line); }
  .exp-row .year { color: var(--accent); font-size: 12px; }
  .exp-row .co { font-size: 14px; color: var(--text); }
  .exp-row .role-l { font-size: 12px; color: var(--muted); margin-top: 4px; }
  .exp-row .note-l { font-size: 12px; color: var(--muted); margin-top: 6px; line-height: 1.6; }

  .repos-head {
    margin-top: 48px;
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
  }
  .repos-head .lbl {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.22em;
    text-transform: uppercase;
  }
  .repos-head .rule {
    height: 1px;
    background: repeating-linear-gradient(90deg, var(--line) 0 6px, transparent 6px 12px);
  }
  .repos-head .meta { font-family: var(--mono); font-size: 11px; color: var(--muted); }
  .repos-head .all-link {
    font-family: var(--mono);
    font-size: 11px;
    color: var(--accent);
    text-decoration: none;
  }

  .edu-certs-contact {
    margin-top: 48px;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 28px;
    padding-top: 28px;
    border-top: 1px solid var(--line-2);
  }
  .subhead {
    font-family: var(--mono);
    font-size: 10px;
    color: var(--muted-2);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin-bottom: 8px;
  }
  .edu-row { font-size: 12px; margin-bottom: 8px; }
  .edu-row .edu-year { color: var(--accent); font-size: 11px; }
  .edu-row .edu-degree { color: var(--text); }
  .edu-row .edu-school { color: var(--muted); }
  .cert-row { font-size: 11.5px; color: var(--muted); line-height: 1.8; }

  .contact-list {
    font-size: 12px;
    line-height: 2;
    color: var(--muted);
    display: grid;
    gap: 2px;
  }
  .contact-list > div {
    display: grid;
    grid-template-columns: 70px 1fr;
    gap: 12px;
    align-items: baseline;
  }
  .contact-list .k { color: var(--muted-2); }
  .contact-list .v { color: var(--accent); text-decoration: none; word-break: break-all; }
  .contact-list .v:hover { text-decoration: underline; }
</style>
